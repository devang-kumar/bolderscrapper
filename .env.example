# Copy this file to .env and fill in your actual values

POSTGRES_USER=bolders
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=job_market
DATABASE_URL=postgresql://user:password@host:5432/job_market

# Scraper config
# Freelancer: 8 keywords * 25 limit = ~200 jobs
FREELANCER_KEYWORDS=developer,data,marketing,design,engineer,analyst,devops,finance
FREELANCER_LIMIT=25

# LinkedIn: multiple keywords * 5 locations = up to ~300 jobs
LINKEDIN_KEYWORD=developer,engineer,analyst,designer,marketing,data scientist
LINKEDIN_LOCATIONS=Netherlands,Germany,France,Belgium,Spain

# EURES: 8 keywords * 25 per page = ~200 jobs
EURES_KEYWORDS=developer,data scientist,marketing,designer,engineer,analyst,devops,accountant
EURES_RESULTS_PER_PAGE=25

# Indeed: 3 queries * 3 countries * 20 max = ~180 jobs
INDEED_QUERY=developer,engineer,data analyst
INDEED_COUNTRIES=nl:Netherlands,de:Germany,fr:France
INDEED_MAX_PER_COUNTRY=20

# Kaggle dataset fallback
KAGGLE_MAX_PARQUET_FILES=5
KAGGLE_DAYS_BACK=60
KAGGLE_FALLBACK_ROWS=500

# Malt: 4 keywords * 3 locations * 20 max = ~240 jobs
MALT_KEYWORDS=developer,data scientist,designer,marketing
MALT_MAX_PER_KEYWORD=20
MALT_LOCATIONS=netherlands,germany,france

# Dashboard config
DASHBOARD_CACHE_TTL=300
